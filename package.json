{
  "name": "sme-monitoreo-workspace",
  "version": "1.0.0",
  "description": "Sistema de Monitoreo de Enlaces (SME) - IMSS Baja California",
  "private": true,
  "workspaces": [
    "shared",
    "backend-api",
    "monitor-service",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "build:all": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace=backend-api",
    "dev:frontend": "npm run dev --workspace=frontend",
    "start:monitor": "npm run start --workspace=monitor-service"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/sqlite3": "^3.1.11",
    "sqlite3": "^6.0.1",
    "ts-node": "^10.9.2"
  }
}
